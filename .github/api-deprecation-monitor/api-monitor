#!/usr/bin/env python3
"""API Deprecation Monitor CLI."""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

import yaml

DEFAULT_CONFIG = ".github/api-deprecation-monitor/config.yaml"
CATALOG_DIR = "api-deprecation-monitor/api-catalog"
CACHE_DIR = "api-deprecation-monitor/api-cache"
REPORTS_DIR = "api-deprecation-monitor/api-reports"
SCAN_STATE_FILE = "api-deprecation-monitor/api-catalog/scan_state.yaml"


def repo_root() -> Path:
    env = os.environ.get("API_MONITOR_REPO_ROOT")
    if env:
        return Path(env).resolve()
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    )
    return Path(result.stdout.strip()).resolve()


def workspace_root(root: Path) -> Path:
    env = os.environ.get("API_MONITOR_WORKSPACE")
    if env:
        return Path(env).resolve()
    return root.parent


def load_config(path: Path) -> dict[str, Any]:
    with path.open() as f:
        return yaml.safe_load(f) or {}


def load_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    with path.open() as f:
        return yaml.safe_load(f) or {}


def save_yaml(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w") as f:
        yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)


def iso_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def git_cmd(cwd: Path, *args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        cwd=cwd,
        capture_output=True,
        text=True,
        check=False,
    )


def resolve_repo_path(root: Path, ws: Path, directory: str) -> Path:
    if directory == ".":
        return root
    return ws / directory


def cmd_sync_workspace(args: argparse.Namespace) -> int:
    root = repo_root()
    ws = workspace_root(root)
    config = load_config(Path(args.config))
    ws.mkdir(parents=True, exist_ok=True)
    for repo in config.get("repos", []):
        directory = repo.get("directory", ".")
        if directory == ".":
            continue
        target = ws / directory
        if target.exists():
            print(f"  {repo['name']}: already present at {target}")
            continue
        url = repo.get("clone_url")
        if not url:
            print(f"  {repo['name']}: skip clone (no clone_url, directory={directory})")
            continue
        print(f"  {repo['name']}: cloning to {target}")
        subprocess.run(["git", "clone", url, str(target)], check=True)
    return 0


def get_dirty_files(repo_path: Path) -> list[str]:
    result = git_cmd(repo_path, "status", "--porcelain")
    if result.returncode != 0:
        return []
    dirty = []
    for line in result.stdout.splitlines():
        if line.strip():
            dirty.append(line[3:].strip())
    return dirty


def get_current_branch(repo_path: Path) -> str:
    result = git_cmd(repo_path, "rev-parse", "--abbrev-ref", "HEAD")
    return result.stdout.strip() if result.returncode == 0 else "unknown"


def get_head_commit(repo_path: Path) -> str:
    result = git_cmd(repo_path, "rev-parse", "HEAD")
    return result.stdout.strip() if result.returncode == 0 else ""


def get_changed_files_since(repo_path: Path, since_commit: str) -> list[str]:
    if not since_commit:
        return []
    result = git_cmd(repo_path, "diff", "--name-only", f"{since_commit}..HEAD")
    if result.returncode != 0:
        return []
    return [f for f in result.stdout.splitlines() if f.strip()]


def cmd_prepare(args: argparse.Namespace) -> int:
    root = repo_root()
    ws = workspace_root(root)
    config_path = Path(args.config)
    if not config_path.is_absolute():
        config_path = root / config_path
    config = load_config(config_path)
    scan_state = load_yaml(root / SCAN_STATE_FILE)

    repo_filter = set(args.repos.split(",")) if args.repos else None
    allow_dirty = set(args.allow_dirty.split(",")) if args.allow_dirty else set()
    switch_branch = args.switch_branch
    keep_branch = set(args.keep_branch.split(",")) if args.keep_branch else set()

    non_master: list[dict[str, str]] = []
    dirty_repos: list[dict[str, str]] = []
    delta_repos: list[dict[str, Any]] = []

    for repo_cfg in config.get("repos", []):
        name = repo_cfg["name"]
        if repo_filter and name not in repo_filter:
            continue
        repo_path = resolve_repo_path(root, ws, repo_cfg.get("directory", "."))
        default_branch = repo_cfg.get("default_branch", "master")
        branch = get_current_branch(repo_path)
        dirty = get_dirty_files(repo_path)

        if dirty and name not in allow_dirty:
            dirty_repos.append({"name": name, "branch": branch, "dirty_files": dirty[:10]})
            continue

        if branch != default_branch and name not in keep_branch:
            if switch_branch:
                git_cmd(repo_path, "checkout", switch_branch)
                branch = switch_branch
            else:
                non_master.append({"name": name, "branch": branch, "default_branch": default_branch})
                continue

        head = get_head_commit(repo_path)
        prev = scan_state.get("repos", {}).get(name, {})
        prev_commit = prev.get("last_scan_commit", "")
        prev_at = prev.get("last_scanned_at", "")

        if args.check_only:
            scan_mode = "skip"
            changed_files: list[str] = []
        elif args.full_scan or not prev_commit:
            scan_mode = "full"
            changed_files = []
        else:
            changed_files = get_changed_files_since(repo_path, prev_commit)
            scan_mode = "delta" if changed_files else "skip"

        delta_repos.append(
            {
                "name": name,
                "repo_path": str(repo_path),
                "github_remote": repo_cfg.get("github_remote", ""),
                "head_commit": head,
                "scan_mode": scan_mode,
                "changed_files": changed_files,
                "branch": branch,
            }
        )

    if non_master and not switch_branch and not keep_branch:
        print(json.dumps({"exit": 2, "non_master": non_master}))
        return 2
    if dirty_repos and not allow_dirty:
        print(json.dumps({"exit": 3, "dirty_repos": dirty_repos}))
        return 3

    output = {
        "exit": 0,
        "check_only": args.check_only,
        "full_scan": args.full_scan,
        "delta": {"repos": delta_repos},
        "run_notes": [],
    }
    print(json.dumps(output))
    return 0


def merge_repo_result(catalog: dict[str, Any], result: dict[str, Any]) -> None:
    repo_name = result["repo"]
    repos = catalog.setdefault("repos", {})
    repo_entry = repos.setdefault(repo_name, {"endpoints": [], "dependencies": [], "last_scan_commit": ""})
    repo_entry["last_scanned_at"] = result.get("scanned_at", iso_now())
    repo_entry["last_scan_commit"] = result.get("head_commit", repo_entry.get("last_scan_commit", ""))
    repo_entry["scan_mode"] = result.get("scan_mode", "full")

    existing_ids = {e["id"] for e in repo_entry.get("endpoints", [])}
    for ep in result.get("endpoints", []):
        if ep["id"] not in existing_ids:
            repo_entry.setdefault("endpoints", []).append(ep)
            existing_ids.add(ep["id"])
        else:
            for i, existing in enumerate(repo_entry["endpoints"]):
                if existing["id"] == ep["id"]:
                    repo_entry["endpoints"][i] = ep
                    break

    dep_key = lambda d: (d.get("name"), d.get("file", ""))
    existing_deps = {dep_key(d) for d in repo_entry.get("dependencies", [])}
    for dep in result.get("dependencies", []):
        if dep_key(dep) not in existing_deps:
            repo_entry.setdefault("dependencies", []).append(dep)


def cmd_merge_catalog(args: argparse.Namespace) -> int:
    root = repo_root()
    catalog_path = root / CATALOG_DIR / "catalog.yaml"
    catalog = load_yaml(catalog_path)
    if not catalog:
        catalog = {"schema_version": 1, "last_updated": iso_now(), "repos": {}}

    results_path = Path(args.results_file)
    with results_path.open() as f:
        content = f.read()
    docs = list(yaml.safe_load_all(content))
    for doc in docs:
        if doc:
            merge_repo_result(catalog, doc)

    catalog["last_updated"] = iso_now()
    platforms: dict[str, int] = {}
    total = 0
    for repo_data in catalog.get("repos", {}).values():
        for ep in repo_data.get("endpoints", []):
            platform = ep.get("platform", "other")
            platforms[platform] = platforms.get(platform, 0) + 1
            total += 1
    catalog["summary"] = {"total_endpoints": total, "platforms": platforms}
    save_yaml(catalog_path, catalog)

    scan_state = load_yaml(root / SCAN_STATE_FILE)
    scan_state.setdefault("repos", {})
    for repo_name, repo_data in catalog.get("repos", {}).items():
        scan_state["repos"][repo_name] = {
            "last_scanned_at": repo_data.get("last_scanned_at"),
            "last_scan_commit": repo_data.get("last_scan_commit"),
        }
    save_yaml(root / SCAN_STATE_FILE, scan_state)

    print(f"Catalog updated: {total} endpoints tracked across {len(platforms)} platforms")
    return 0


SOURCE_URLS = {
