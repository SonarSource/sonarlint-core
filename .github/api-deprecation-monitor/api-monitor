    "gitlab_api_deprecations.md": "https://docs.gitlab.com/api/rest/deprecations/",
    "gitlab_all_deprecations.md": "https://docs.gitlab.com/update/deprecations/",
    "bitbucket_changelog.md": "https://developer.atlassian.com/cloud/bitbucket/changelog/",
    "jira_changelog.md": "https://developer.atlassian.com/cloud/jira/platform/changelog/",
    "slack_changelog.md": "https://api.slack.com/changelog",
    "sonarqube_deprecations.md": "https://docs.sonarsource.com/sonarqube-server/latest/server-upgrade-and-maintenance/release-upgrade-notes/",
    "sonarqube_web_api.md": "https://docs.sonarsource.com/sonarqube-server/latest/extension-guide/web-api/",
    "sonarcloud_changelog.md": "https://docs.sonarsource.com/sonarcloud/whats-new/",
}


def fetch_url(url: str) -> str:
    import urllib.request

    req = urllib.request.Request(url, headers={"User-Agent": "api-deprecation-monitor/1.0"})
    with urllib.request.urlopen(req, timeout=60) as resp:
        return resp.read().decode("utf-8", errors="replace")


def cmd_fetch_sources(args: argparse.Namespace) -> int:
    root = repo_root()
    sources_dir = root / CACHE_DIR / "sources"
    sources_dir.mkdir(parents=True, exist_ok=True)
    meta_path = root / CACHE_DIR / "fetch_meta.yaml"
    meta = load_yaml(meta_path)
    max_age_hours = 24
    if args.max_age.endswith("h"):
        max_age_hours = int(args.max_age[:-1])

    now = datetime.now(timezone.utc)
    fetched: list[str] = []
    skipped: list[str] = []
    errors: list[str] = []

    for filename, url in SOURCE_URLS.items():
        dest = sources_dir / filename
        prev = meta.get("files", {}).get(filename, {})
        if dest.exists() and prev.get("fetched_at"):
            try:
                fetched_at = datetime.fromisoformat(prev["fetched_at"].replace("Z", "+00:00"))
                age_h = (now - fetched_at).total_seconds() / 3600
                if age_h < max_age_hours:
                    skipped.append(filename)
                    continue
            except (ValueError, TypeError):
                pass
        try:
            content = fetch_url(url)
            dest.write_text(content, encoding="utf-8")
            meta.setdefault("files", {})[filename] = {
                "fetched_at": iso_now(),
                "source_url": url,
                "size": len(content),
            }
            fetched.append(filename)
        except Exception as exc:
            errors.append(f"{filename}: {exc}")
            if not dest.exists():
                dest.write_text(f"# Fetch failed: {exc}\n# Source: {url}\n", encoding="utf-8")

    meta["last_fetch"] = iso_now()
    save_yaml(meta_path, meta)

    catalog = load_yaml(root / CATALOG_DIR / "catalog.yaml")
    deprecations = load_yaml(root / CATALOG_DIR / "deprecations.yaml")
    platforms_in_catalog = set()
    for repo_data in catalog.get("repos", {}).values():
        for ep in repo_data.get("endpoints", []):
            platforms_in_catalog.add(ep.get("platform", "other"))

    catalog_updated = catalog.get("last_updated", "")
    deprec_checked = deprecations.get("last_checked", "")
    platforms_to_check = sorted(platforms_in_catalog) if fetched else []

    result = {
        "fetched": fetched,
        "skipped": skipped,
        "errors": errors,
        "platforms_to_check": platforms_to_check,
        "catalog_last_updated": catalog_updated,
        "deprecations_last_checked": deprec_checked,
        "cached_source_files": {k: str(sources_dir / k) for k in SOURCE_URLS},
    }
    print(json.dumps(result))
    return 0


def cmd_merge_verifications(args: argparse.Namespace) -> int:
    root = repo_root()
    dep_path = root / CATALOG_DIR / "deprecations.yaml"
    deprecations = load_yaml(dep_path)
    if not deprecations:
        deprecations = {"schema_version": 1, "last_checked": iso_now(), "deprecations": []}

    verdicts_path = Path(args.verdicts_file)
    with verdicts_path.open() as f:
        content = f.read()
    verdicts = list(yaml.safe_load_all(content))

    by_id = {d["id"]: d for d in deprecations.get("deprecations", [])}
    for verdict_doc in verdicts:
        if not verdict_doc:
            continue
        dep_id = verdict_doc.get("deprecation_id")
        if dep_id not in by_id:
            continue
        entry = by_id[dep_id]
        entry["verified_at"] = iso_now()
        entry["verification"] = {
            "verdict": verdict_doc.get("verdict"),
            "verified_repos": verdict_doc.get("verified_repos", []),
            "evidence": verdict_doc.get("evidence", []),
            "notes": verdict_doc.get("notes", ""),
        }
        if verdict_doc.get("verdict") == "false_positive":
            entry["status"] = "false_positive"

    deprecations["deprecations"] = list(by_id.values())
    save_yaml(dep_path, deprecations)
    print(f"Merged {len([v for v in verdicts if v])} verification verdicts")
    return 0


def severity_from_sunset(sunset: str, today: str) -> str:
    try:
        sunset_dt = datetime.strptime(sunset[:10], "%Y-%m-%d").date()
        today_dt = datetime.strptime(today[:10], "%Y-%m-%d").date()
        days = (sunset_dt - today_dt).days
        if days <= 90:
            return "critical"
        if days <= 180:
            return "warning"
        return "info"
    except (ValueError, TypeError):
        return "info"


def cmd_generate_report(args: argparse.Namespace) -> int:
    root = repo_root()
    catalog = load_yaml(root / CATALOG_DIR / "catalog.yaml")
    deprecations = load_yaml(root / CATALOG_DIR / "deprecations.yaml")
    trigger = args.trigger or "cron"
    run_notes = json.loads(args.run_notes) if args.run_notes else []
    repos_scanned = json.loads(args.repos_scanned) if args.repos_scanned else []
    repos_skipped = json.loads(args.repos_skipped) if args.repos_skipped else []

    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    active_deps = [
        d
        for d in deprecations.get("deprecations", [])
        if d.get("affected_repos")
        and d.get("status", "open") in ("open", "missing")
        and d.get("verification", {}).get("verdict") != "false_positive"
    ]

    critical = [d for d in active_deps if d.get("severity") == "critical"]
    warning = [d for d in active_deps if d.get("severity") == "warning"]

    lines = [
        "# API Deprecation Monitor Report",
        f"**Generated:** {iso_now()} · **Trigger:** {trigger}",
        f"**Repos scanned:** {', '.join(repos_scanned) or 'none'} · **Repos skipped:** {', '.join(repos_skipped) or 'none'}",
        "",
        "## Run notes",
    ]
    if run_notes:
        lines.extend(f"- {n}" for n in run_notes)
    else:
        lines.append("- No issues during prepare/bootstrap.")

    lines.extend(["", "## Recommended Actions"])
    if not active_deps:
        lines.append("No new action needed this week — no active deprecations affecting cataloged endpoints.")
    else:
        for i, dep in enumerate(active_deps, 1):
            kind = dep.get("kind", "deprecation")
            lines.append(
                f"{i}. **[{dep.get('severity', 'info').upper()}]** {dep.get('title')} "
                f"({kind}) — sunset {dep.get('sunset_date', 'TBD')}"
            )

    lines.extend(["", "## Findings", "", "### Deprecations"])
    lines.append(
        "| Kind | Endpoint | Platform | Sunset | Severity | Repos | Source |"
    )
    lines.append("|---|---|---|---|---|---|---|")
    for dep in deprecations.get("deprecations", []):
        if not dep.get("affected_repos"):
            continue
        repos = ", ".join(r["repo"] for r in dep["affected_repos"])
        src = f"[source notice]({dep.get('source_url', '#')})"
        lines.append(
            f"| {dep.get('kind', 'deprecation')} | {dep.get('affected_endpoint', '')} "
            f"| {dep.get('platform', '')} | {dep.get('sunset_date', '')} "
            f"| {dep.get('severity', '')} | {repos} | {src} |"
        )

    for dep in deprecations.get("deprecations", []):
        if not dep.get("affected_repos"):
            continue
        lines.extend(
            [
                "",
                f"### [{dep['id']}] {dep.get('title', '')}",
                f"- Kind: {dep.get('kind', 'deprecation')}, platform: {dep.get('platform')}, "
                f"endpoint: `{dep.get('affected_endpoint', '')}`",
                f"- Announced: {dep.get('announcement_date', '')}, sunset: {dep.get('sunset_date', '')}, "
                f"severity: {dep.get('severity', '')}",
            ]
        )
        if dep.get("replacement"):
            lines.append(f"- Replacement: {dep['replacement']}")
        for ar in dep.get("affected_repos", []):
            remote = "SonarSource/sonarlint-core"
            commit = catalog.get("repos", {}).get(ar["repo"], {}).get("last_scan_commit", "master")
            for f in ar.get("files", []):
                link = f"https://github.com/{remote}/blob/{commit}/{f}"
                lines.append(f"- [{ar['repo']}] [{f}]({link})")
        if dep.get("source_url"):
            lines.append(f"- [source notice]({dep['source_url']})")

    lines.extend(["", "## Catalog Summary", "| Platform | Endpoints | Repos |", "|---|---|---|"])
    platform_repos: dict[str, set[str]] = {}
    platform_counts: dict[str, int] = {}
    for repo_name, repo_data in catalog.get("repos", {}).items():
        for ep in repo_data.get("endpoints", []):
            p = ep.get("platform", "other")
            platform_counts[p] = platform_counts.get(p, 0) + 1
            platform_repos.setdefault(p, set()).add(repo_name)
    for p, count in sorted(platform_counts.items()):
        lines.append(f"| {p} | {count} | {', '.join(sorted(platform_repos[p]))} |")

    lines.extend(["", "## SDK/Library Versions", "| Library | Version | Repos |", "|---|---|---|"])
    lib_repos: dict[str, dict[str, set[str]]] = {}
    for repo_name, repo_data in catalog.get("repos", {}).items():
        for dep in repo_data.get("dependencies", []):
            name = dep.get("name", "")
            ver = dep.get("version", "")
            lib_repos.setdefault(name, {}).setdefault(ver, set()).add(repo_name)
    for name in sorted(lib_repos):
        for ver, repos in sorted(lib_repos[name].items()):
            lines.append(f"| {name} | {ver} | {', '.join(sorted(repos))} |")

    report_path = root / REPORTS_DIR / "report_latest.md"
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text("\n".join(lines) + "\n", encoding="utf-8")

    if active_deps:
        summary_first = f"Action needed: {len(active_deps)} open deprecation(s) affect cataloged endpoints ({len(critical)} critical, {len(warning)} warning)."
        highest = active_deps[0]
        days = ""
        if highest.get("sunset_date"):
            try:
                d = (datetime.strptime(highest["sunset_date"][:10], "%Y-%m-%d").date() -
                     datetime.strptime(today, "%Y-%m-%d").date()).days
                days = f" ({d} days)"
            except ValueError:
                pass
        highest_signal = f"{highest.get('title')}: review {highest.get('affected_endpoint', '')} usage{days}."
    else:
        summary_first = "No new action needed this week — no verified deprecations affect cataloged endpoints."
        highest_signal = "Continue monitoring; no actionable deprecation findings."

    slack = {"summary": summary_first, "highest_signal": highest_signal}
    slack_path = root / REPORTS_DIR / "slack_summary.json"
    slack_path.write_text(json.dumps(slack, indent=2) + "\n", encoding="utf-8")

    print(f"Report written to {REPORTS_DIR}/report_latest.md")
    if critical or warning:
        print(f"⚠ ATTENTION: {len(critical)} CRITICAL, {len(warning)} WARNING deprecation(s) affecting code")
    else:
        print("✓ No active deprecations or compatibility notices affecting cataloged endpoints.")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="API Deprecation Monitor")
    parser.add_argument("--config", default=os.environ.get("API_MONITOR_CONFIG", DEFAULT_CONFIG))
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("sync-workspace")
    p_prepare = sub.add_parser("prepare")
    p_prepare.add_argument("--repos")
    p_prepare.add_argument("--full-scan", action="store_true")
    p_prepare.add_argument("--check-only", action="store_true")
    p_prepare.add_argument("--allow-dirty")
    p_prepare.add_argument("--switch-branch")
    p_prepare.add_argument("--keep-branch")

    p_merge = sub.add_parser("merge-catalog")
    p_merge.add_argument("--results-file", required=True)

    p_fetch = sub.add_parser("fetch-sources")
    p_fetch.add_argument("--max-age", default="24h")

    p_ver = sub.add_parser("merge-verifications")
    p_ver.add_argument("--verdicts-file", required=True)

    p_report = sub.add_parser("generate-report")
    p_report.add_argument("--trigger", default="cron")
    p_report.add_argument("--run-notes", default="[]")
    p_report.add_argument("--repos-scanned", default="[]")
    p_report.add_argument("--repos-skipped", default="[]")

    args = parser.parse_args()
    handlers = {
        "sync-workspace": cmd_sync_workspace,
        "prepare": cmd_prepare,
        "merge-catalog": cmd_merge_catalog,
        "fetch-sources": cmd_fetch_sources,
        "merge-verifications": cmd_merge_verifications,
        "generate-report": cmd_generate_report,
    }
    return handlers[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
